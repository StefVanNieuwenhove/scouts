generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Camps {
  id           String    @id @default(uuid())
  name         Kamp_type @default(overgangsweekend)
  start_date   DateTime
  end_date     DateTime
  cost_per_day Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  total_days   Int
  members      Members[]
}

model Members {
  id              String        @id @default(uuid())
  member_id       String        @unique
  firstname       String
  lastname        String
  date_of_birth   DateTime
  group           Lid_tak       @default(kapoenen)
  national_number String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  parents         Parents[]
  activities     Activity[]
  camps           Camps[]
}

model Parents {
  id                 String   @id @default(uuid())
  firstname          String
  lastname           String
  email              String  @unique
  street             String
  house_number       String
  box_number         String?
  zip_code           String
  city               String
  national_number String @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  member_id          String
  members            Members  @relation(fields: [member_id], references: [id], onDelete: Cascade, map: "Ouder_MemberConstraint")

  @@index([member_id], map: "Ouder_member_id_fkey")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique 
  name      String
  password  String
  role      User_role[] @default([kapoen])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Activity {
  id          String          @id
  titel       String
  datum       DateTime
  tak         Vergadering_tak @default(kapoenen)
  userUpdated String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  member_id   String
  members     Members         @relation(fields: [member_id], references: [id], onDelete: Cascade, map: "Vergadering_MemberConstraint")

  @@index([member_id], map: "Vergadering_member_id_fkey")
  @@index([userUpdated], map: "Vergadering_userUpdated_fkey")
}

enum Kamp_type {
  overgangsweekend
  paaskamp
  zomerkamp_kort
  zomerkamp_lang
}

enum Lid_tak {
  kapoenen
  wouters
  jonggivers
  givers
  jins
}

enum User_role {
  admin
  kapoen
  wouter
  jonggiver
  giver
  jin
  groepsleiding
  rvb
  parent
}

enum Vergadering_tak {
  kapoenen
  wouters
  jonggivers
  givers
  jins
}
