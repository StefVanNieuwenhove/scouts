generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Lid {
  lidnummer     String        @id 
  voornaam      String
  achternaam    String
  email         String        @unique
  geboortedatum DateTime
  tak           Lid_tak       @default(kapoenen)
  geslacht      Lid_geslacht  @default(onbekend)
  straat        String
  huisnummer    String
  busnummer     String
  postcode      String
  gemeente      String
  rijksregisternummer String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ouder         Ouder[]
  vergadering   Vergadering[]
  kamp       Kamp[]
}

model Ouder {
  id         String        @id @default(uuid())
  voornaam   String
  achternaam String
  email      String        
  functie    Ouder_functie @default(andere)
  gsm        String        @unique 
  straat     String
  huisnummer String
  busnummer  String
  postcode   String
  gemeente   String
  rijkregisternummer String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime     @updatedAt
  lidnummer  String
  Lid        Lid           @relation(fields: [lidnummer], references: [lidnummer], onDelete: Cascade, map: "Ouder_LidConstraint")

  @@index([lidnummer], map: "Ouder_lidnummer_fkey")
}

model User {
  id          String        @id @default(uuid())
  email       String        @unique
  name        String
  password    String
  role        User_role     @default(kapoen)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt  
}

model Vergadering {
  id          String          @id @default(uuid())
  titel       String
  datum       DateTime
  tak         Vergadering_tak @default(kapoenen)
  userUpdated String
  lidnummer   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime      @updatedAt
  Lid         Lid             @relation(fields: [lidnummer], references: [lidnummer], onDelete: Cascade, map: "Vergadering_LidConstraint")

  @@index([lidnummer], map: "Vergadering_lidnummer_fkey")
  @@index([userUpdated], map: "Vergadering_userUpdated_fkey")
}

model Kamp  {
  id         String          @id @default(uuid())
  name       Kamp_type       @default(overgangsweekend)
  start_date  DateTime
  end_date    DateTime
  total_days Int
  cost_per_day Float
  createdAt  DateTime        @default(now())
  updatedAt  DateTime      @updatedAt
  leden     Lid[]
}

enum Vergadering_tak {
  kapoenen
  wouters
  jonggivers
  givers
  jins
}

enum Ouder_functie {
  moeder
  vader
  voogd
  grootouder
  andere
}

enum User_role {
  admin
  kapoen
  wouter
  jonggiver
  giver
  jin
groepsleiding
  board
  parent
}

enum Lid_tak {
  kapoenen
  wouters
  jonggivers
  givers
  jins
}

enum Lid_geslacht {
  man
  vrouw
  onbekend
}

enum Kamp_type {
  overgangsweekend
  paaskamp
  zomerkamp_kort
  zomerkamp_lang
}